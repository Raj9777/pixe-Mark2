# ─────────────────────────────────────────────────────────────
# PIXE — EmailJS Configuration
# Copy this file to .env and fill in your real values.
# .env is gitignored — NEVER commit real keys.
# Get your keys at: https://www.emailjs.com
# ─────────────────────────────────────────────────────────────

# Your EmailJS Service ID (from Email Services tab)
# Example: service_abc1234
VITE_EMAILJS_SERVICE_ID=service_xxxxxxx

# Your EmailJS Public Key (from Account → General)
# Example: xAbCdEfGhIjKlMnOp
VITE_EMAILJS_PUBLIC_KEY=your_public_key_here

# Template 1: Owner notification (booking alert to ratanraj9777@gmail.com)
# Subject: 🔔 New Booking: {{from_name}} — {{service}}
# To:      ratanraj9777@gmail.com (hardcoded in template)
VITE_EMAILJS_TEMPLATE_BOOKING=template_xxxxxxx

# Template 2: Customer confirmation (sent to the person who booked)
# Subject: ✅ Your call with PIXE is confirmed — {{booking_date}} at {{booking_time}}
# To:      {{to_email}}  ← must use this variable in the template's "To Email" field
VITE_EMAILJS_TEMPLATE_CONFIRMATION=template_yyyyyyy

# Template 3: Contact page form notification (to ratanraj9777@gmail.com)
VITE_EMAILJS_TEMPLATE_CONTACT=template_zzzzzzz

# ─────────────────────────────────────────────────────────────
# PIXE — Supabase Configuration
# ─────────────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://your_project_ref.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_public_key

